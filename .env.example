# Instance name (used as container prefix)
PROJECT_NAME=mydb

# Database engine: mariadb | mysql | postgres
DB_ENGINE=mariadb

# Docker image tag (e.g. 11, 10.11, 8.0, 16)
DB_VERSION=11

# Credentials
DB_ROOT_PASSWORD=root
DB_DATABASE=
DB_USER=
DB_PASSWORD=

# Host-exposed ports
DB_PORT=23306
DB_ADMIN_PORT=28080

# Seed files from the seed/ folder
# Format: file.sql or file.sql:dbname (comma-separated for multiple)
# Examples: gescom.sql  |  licencesdb.sql:licencesdb,gtpdb500001.sql:gtpdb500001
DB_SEED_FILES=
DB_RESEED_ON_STARTUP=false
